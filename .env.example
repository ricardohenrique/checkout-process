APP_NAME="Checkout Assessment"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is set to :memory: in phpunit.xml for tests.
# For local dev, set this to the absolute path of your sqlite file:
# DB_DATABASE=/absolute/path/to/database/database.sqlite

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

MAIL_MAILER=log

# Mock payment gateway — no real credentials needed for the assessment
PAYMENT_GATEWAY_URL=https://mock-gateway.example.com
